@page
@model DataBridge.Api.Pages.IndexModel
@{
    ViewData["Title"] = "FNA Tools";
    ViewData["ActivePage"] = "hub";
}

@* ── Topbar ───────────────────────────────────────────────────── *@
<div class="topbar">
  <div class="topbar-title">
    <h1>FNA Tools</h1>
    <div class="sub">Your automation toolkit</div>
  </div>
  <div class="topbar-right">
    <button class="tb-icon-btn" title="Notifications">
      <svg width="18" height="18"><use href="#ic-bell"/></svg>
    </button>
    <button class="tb-icon-btn" title="Help">
      <svg width="18" height="18"><use href="#ic-help"/></svg>
    </button>
    <div class="tb-avatar">@(string.Concat((User.FindFirstValue("DataBridgeDisplayName") ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => char.ToUpper(w[0]))))</div>
  </div>
</div>

@* ── Page content ─────────────────────────────────────────────── *@
<div class="page">

  @* Filter bar *@
  <div class="filter-bar">
    <div class="ftab active" data-tab="all">All Tools</div>
    <div class="ftab" data-tab="data">Data</div>
    <div class="ftab" data-tab="reporting">Reporting</div>
    <div class="ftab" data-tab="utilities">Utilities</div>
    <div class="filter-right">
      <div class="search">
        <svg class="search-ico" width="14" height="14"><use href="#ic-search"/></svg>
        <input type="text" id="toolSearch" placeholder="Search tools…" />
      </div>
      <button class="sort-btn">
        <svg width="13" height="13"><use href="#ic-sort"/></svg>
        Sort: Recent
        <svg width="13" height="13"><use href="#ic-chevron-d"/></svg>
      </button>
    </div>
  </div>

  @* Tool grid *@
  <div class="tool-grid" id="toolGrid">

    @* Active: Pipeline *@
    <a class="tool-card" href="/Clean" style="border-left-color:#2E75B6" data-category="data"
       data-title="Pipeline" data-desc="Import, clean, and export in a single end-to-end workflow.">
      <div class="row1">
        <div class="tool-icon" style="background:#2E75B6">
          <svg width="20" height="20"><use href="#ic-pipeline"/></svg>
        </div>
        <span class="badge badge-success"><span class="badge-dot"></span> Available</span>
      </div>
      <h3 class="tool-title">Pipeline</h3>
      <p class="tool-desc">Import, clean, and export in a single end-to-end workflow.</p>
      <span class="tool-cta">Open <svg width="13" height="13" style="display:inline"><use href="#ic-arrow-r"/></svg></span>
    </a>

    @* Active: Quick Import *@
    <a class="tool-card" href="/Import" style="border-left-color:#5B6CCB" data-category="data"
       data-title="Quick Import" data-desc="Upload Excel files directly to a SQL staging table.">
      <div class="row1">
        <div class="tool-icon" style="background:#5B6CCB">
          <svg width="20" height="20"><use href="#ic-upload"/></svg>
        </div>
        <span class="badge badge-success"><span class="badge-dot"></span> Available</span>
      </div>
      <h3 class="tool-title">Quick Import</h3>
      <p class="tool-desc">Upload Excel files directly to a SQL staging table.</p>
      <span class="tool-cta">Open <svg width="13" height="13" style="display:inline"><use href="#ic-arrow-r"/></svg></span>
    </a>

    @* Active: Quick Export *@
    <a class="tool-card" href="/Export" style="border-left-color:#2BA39A" data-category="data"
       data-title="Quick Export" data-desc="Query SQL Server and download results as a formatted Excel file.">
      <div class="row1">
        <div class="tool-icon" style="background:#2BA39A">
          <svg width="20" height="20"><use href="#ic-download"/></svg>
        </div>
        <span class="badge badge-success"><span class="badge-dot"></span> Available</span>
      </div>
      <h3 class="tool-title">Quick Export</h3>
      <p class="tool-desc">Query SQL Server and download results as a formatted Excel file.</p>
      <span class="tool-cta">Open <svg width="13" height="13" style="display:inline"><use href="#ic-arrow-r"/></svg></span>
    </a>

    @* Coming soon *@
    <div class="tool-card is-disabled" style="border-left-color:#DDE4ED" data-category="reporting"
         data-title="Reconciliation" data-desc="Match GL and sub-ledger balances side-by-side with variance flags.">
      <div class="row1">
        <div class="tool-icon"><svg width="20" height="20"><use href="#ic-scale"/></svg></div>
        <span class="badge badge-muted">Coming Soon</span>
      </div>
      <h3 class="tool-title">Reconciliation</h3>
      <p class="tool-desc">Match GL and sub-ledger balances side-by-side with variance flags.</p>
    </div>

    <div class="tool-card is-disabled" style="border-left-color:#DDE4ED" data-category="reporting"
         data-title="Report Builder" data-desc="Compose recurring FNA reports with saved layouts and schedules.">
      <div class="row1">
        <div class="tool-icon"><svg width="20" height="20"><use href="#ic-chart"/></svg></div>
        <span class="badge badge-muted">Coming Soon</span>
      </div>
      <h3 class="tool-title">Report Builder</h3>
      <p class="tool-desc">Compose recurring FNA reports with saved layouts and schedules.</p>
    </div>

    <div class="tool-card is-disabled" style="border-left-color:#DDE4ED" data-category="utilities"
         data-title="Data Validator" data-desc="Run rule sets against staging tables before downstream loads.">
      <div class="row1">
        <div class="tool-icon"><svg width="20" height="20"><use href="#ic-shield"/></svg></div>
        <span class="badge badge-muted">Coming Soon</span>
      </div>
      <h3 class="tool-title">Data Validator</h3>
      <p class="tool-desc">Run rule sets against staging tables before downstream loads.</p>
    </div>

    <div class="tool-card is-disabled" style="border-left-color:#DDE4ED" data-category="utilities"
         data-title="Scheduler" data-desc="Trigger pipelines on cron expressions or month-end calendar.">
      <div class="row1">
        <div class="tool-icon"><svg width="20" height="20"><use href="#ic-clock"/></svg></div>
        <span class="badge badge-muted">Coming Soon</span>
      </div>
      <h3 class="tool-title">Scheduler</h3>
      <p class="tool-desc">Trigger pipelines on cron expressions or month-end calendar.</p>
    </div>

  </div><!-- /.tool-grid -->

  @* Footer hint *@
  <div style="margin-top:28px;display:flex;align-items:center;justify-content:space-between;
              background:#fff;border:1px dashed var(--border-strong);border-radius:10px;
              padding:14px 20px;color:var(--text-muted)">
    <div style="display:flex;align-items:center;gap:12px">
      <div style="width:36px;height:36px;border-radius:8px;background:var(--blue-100);
                  color:var(--blue-500);display:grid;place-items:center">
        <svg width="18" height="18"><use href="#ic-plus"/></svg>
      </div>
      <div>
        <div style="font-weight:600;color:var(--text)">Got an idea for a new tool?</div>
        <div class="text-sm">Tell the FNA Automation team what to build next — pipelines ship every two weeks.</div>
      </div>
    </div>
    <button class="btn btn-secondary btn-sm">Request a tool</button>
  </div>

  @* Staging table metrics (collapsed by default, available for power users) *@
  @if (Model.Metrics != null)
  {
      <details style="margin-top:24px">
        <summary style="font-size:13px;color:var(--text-muted);cursor:pointer;padding:8px 0;
                        border-top:1px solid var(--border);list-style:none;display:flex;align-items:center;gap:6px">
          <svg width="13" height="13"><use href="#ic-dashboard"/></svg>
          Staging table status
          <svg width="13" height="13" style="margin-left:auto"><use href="#ic-chevron-d"/></svg>
        </summary>
        <div style="margin-top:12px;background:#fff;border:1px solid var(--border);border-radius:10px;overflow:hidden;box-shadow:var(--shadow)">
          <table class="t">
            <thead>
              <tr>
                <th>Table</th><th>Status</th><th>Rows</th><th>Vendor issues</th><th>PO issues</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var t in Model.Metrics.Tables)
              {
                  <tr>
                    <td><span class="mono text-sm">@t.TableName</span></td>
                    <td>
                      @if (t.Exists)
                      {
                          <span class="badge badge-success"><span class="badge-dot"></span> Ready</span>
                      }
                      else
                      {
                          <span class="badge badge-muted">Not created</span>
                      }
                    </td>
                    <td>@(t.Exists ? t.RowCount.ToString("N0") : "—")</td>
                    <td>
                      @if (t.VendorNotFound.HasValue)
                      {
                          <span style="color:@(t.VendorNotFound > 0 ? "var(--amber-500)" : "var(--green-600)");font-weight:600">
                            @t.VendorNotFound.Value.ToString("N0")
                          </span>
                      }
                      else { <span class="muted">N/A</span> }
                    </td>
                    <td>
                      @if (t.PoNotFound.HasValue)
                      {
                          <span style="color:@(t.PoNotFound > 0 ? "var(--amber-500)" : "var(--green-600)");font-weight:600">
                            @t.PoNotFound.Value.ToString("N0")
                          </span>
                      }
                      else { <span class="muted">N/A</span> }
                    </td>
                  </tr>
              }
            </tbody>
          </table>
        </div>
      </details>
  }

</div><!-- /.page -->

@section Scripts {
<script>
  // ── Filter tabs
  document.querySelectorAll('.ftab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      filterTools(tab.dataset.tab, document.getElementById('toolSearch').value);
    });
  });

  // ── Search
  document.getElementById('toolSearch').addEventListener('input', e => {
    const active = document.querySelector('.ftab.active')?.dataset.tab || 'all';
    filterTools(active, e.target.value);
  });

  function filterTools(tab, search) {
    const q = (search || '').toLowerCase();
    document.querySelectorAll('.tool-card').forEach(card => {
      const matchTab = tab === 'all' || card.dataset.category === tab;
      const text = ((card.dataset.title || '') + ' ' + (card.dataset.desc || '')).toLowerCase();
      const matchSearch = !q || text.includes(q);
      card.style.display = (matchTab && matchSearch) ? '' : 'none';
    });
  }
</script>
}
