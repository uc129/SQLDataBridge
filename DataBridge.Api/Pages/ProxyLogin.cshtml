@page
@model DataBridge.Api.Pages.ProxyLoginModel
@{
    Layout = null;
    ViewData["Title"] = "Proxy Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Proxy Login — DataBridge</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100">
    <div class="card shadow" style="width:400px">
        <div class="card-body p-5">
            <h1 class="fs-3 fw-bold text-primary mb-1 text-center">DataBridge</h1>
            <p class="text-muted mb-4 text-center small">Proxy Login</p>

            @if (!ModelState.IsValid)
            {
                <div class="alert alert-danger py-2">
                    @foreach (var err in ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">User</label>
                    <select name="SelectedUserId" class="form-select" required>
                        <option value="">— Select user —</option>
                        @foreach (var u in Model.Users)
                        {
                            <option value="@u.Id">@u.DisplayName (@u.RoleCode)</option>
                        }
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">OTP</label>
                    <input name="Otp" type="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Sign In</button>
            </form>

            <div class="text-center mt-3">
                <a asp-page="/Login" class="text-muted small">← Back to login</a>
            </div>
        </div>
    </div>
</body>
</html>
