@inject IConfiguration Config
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1280, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "FNA Tools") — DataBridge</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@* ── SVG Sprite ───────────────────────────────────────────────── *@
<svg style="display:none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <symbol id="ic-brand" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 9h14M14 5l4 4-4 4"/><path d="M20 15H6M10 19l-4-4 4-4"/>
    </symbol>
    <symbol id="ic-dashboard" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/>
    </symbol>
    <symbol id="ic-pipeline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="5" cy="12" r="2.5"/><circle cx="12" cy="12" r="2.5"/><circle cx="19" cy="12" r="2.5"/><path d="M7.5 12h2M14.5 12h2"/>
    </symbol>
    <symbol id="ic-upload" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 16V4M7 9l5-5 5 5"/><path d="M4 20h16"/>
    </symbol>
    <symbol id="ic-download" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 4v12M7 11l5 5 5-5"/><path d="M4 20h16"/>
    </symbol>
    <symbol id="ic-scale" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 4v16M4 8l8-3 8 3"/><path d="M4 8l-2 6a4 4 0 0 0 8 0L8 8"/><path d="M16 8l-2 6a4 4 0 0 0 8 0L20 8"/>
    </symbol>
    <symbol id="ic-chart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="13" width="4" height="8"/><rect x="10" y="8" width="4" height="13"/><rect x="17" y="4" width="4" height="17"/>
    </symbol>
    <symbol id="ic-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3l8 3v6c0 4.5-3.5 8.5-8 9-4.5-.5-8-4.5-8-9V6l8-3z"/><path d="M9 12l2 2 4-4"/>
    </symbol>
    <symbol id="ic-clock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
    </symbol>
    <symbol id="ic-bell" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 8a6 6 0 0 1 12 0c0 5 2 6 2 8H4c0-2 2-3 2-8z"/><path d="M10 20a2 2 0 0 0 4 0"/>
    </symbol>
    <symbol id="ic-help" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9"/><path d="M9.5 9a2.5 2.5 0 0 1 5 0c0 1.5-2.5 2-2.5 3.5"/><circle cx="12" cy="17" r="0.5" fill="currentColor"/>
    </symbol>
    <symbol id="ic-settings" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1.1-1.5 1.7 1.7 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.8 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.8.3H9a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.8V9a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z"/>
    </symbol>
    <symbol id="ic-chevron-d" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 9 6 6 6-6"/>
    </symbol>
    <symbol id="ic-chevron-r" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m9 6 6 6-6 6"/>
    </symbol>
    <symbol id="ic-arrow-r" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14M13 5l7 7-7 7"/>
    </symbol>
    <symbol id="ic-arrow-l" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 12H5M11 5l-7 7 7 7"/>
    </symbol>
    <symbol id="ic-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="m5 12 5 5L20 7"/>
    </symbol>
    <symbol id="ic-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 6l12 12M18 6 6 18"/>
    </symbol>
    <symbol id="ic-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M5 12h14"/>
    </symbol>
    <symbol id="ic-file-excel" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5M9 13l5 5M14 13l-5 5"/>
    </symbol>
    <symbol id="ic-play" viewBox="0 0 24 24" fill="currentColor" stroke="none">
      <path d="M6 4l14 8-14 8z"/>
    </symbol>
    <symbol id="ic-search" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="6"/><path d="m20 20-3.5-3.5"/>
    </symbol>
    <symbol id="ic-folder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
    </symbol>
    <symbol id="ic-refresh" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/>
    </symbol>
    <symbol id="ic-edit" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/>
    </symbol>
    <symbol id="ic-sort" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 4v16M8 4 4 8M8 4l4 4M16 20V4M16 20l-4-4M16 20l4-4"/>
    </symbol>
  </defs>
</svg>

@* ── App shell ─────────────────────────────────────────────────── *@
<div class="app">

  @* ── Sidebar ─────────────────────────────────────────────── *@
  @{
      var activePage  = ViewData["ActivePage"]?.ToString() ?? "";
      var _user       = HttpContextAccessor.HttpContext?.User;
      var displayName = _user?.FindFirstValue("DataBridgeDisplayName") ?? "DataBridge User";
      var role        = _user?.FindFirstValue("DataBridgeRole") ?? "";
      var initials    = string.Concat(
          displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                     .Take(2).Select(w => char.ToUpper(w[0])));
      var isAdmin     = role == "Admin";
      var authMethod  = _user?.FindFirstValue("DataBridgeAuthMethod") ?? "";
      var signOutUrl  = authMethod == "Proxy" ? "/ProxySignOut" : "/MicrosoftIdentity/Account/SignOut";
  }
  <aside class="sidebar">
    <div class="sb-brand">
      <div class="sb-brand-mark">
        <svg width="16" height="16"><use href="#ic-brand"/></svg>
      </div>
      DataBridge
    </div>

    <div class="sb-section-label">Overview</div>
    <a class="sb-item @(activePage == "hub" ? "active" : "")" href="/">
      <svg class="sb-icon"><use href="#ic-dashboard"/></svg>
      <span>FNA Tools</span>
    </a>

    <div class="sb-section-label">Data Tools</div>
    <a class="sb-item @(activePage == "pipeline" ? "active" : "")" href="/Clean">
      <svg class="sb-icon"><use href="#ic-pipeline"/></svg>
      <span>Pipeline</span>
    </a>
    <a class="sb-item @(activePage == "import" ? "active" : "")" href="/Import">
      <svg class="sb-icon"><use href="#ic-upload"/></svg>
      <span>Quick Import</span>
    </a>
    <a class="sb-item @(activePage == "export" ? "active" : "")" href="/Export">
      <svg class="sb-icon"><use href="#ic-download"/></svg>
      <span>Quick Export</span>
    </a>

    @if (isAdmin)
    {
        <div class="sb-section-label">Administration</div>
        <a class="sb-item @(activePage == "admin-users" ? "active" : "")" href="/Admin/Users">
          <svg class="sb-icon"><use href="#ic-shield"/></svg>
          <span>User Management</span>
          <span class="sb-badge">Admin</span>
        </a>
    }

    <div class="sb-section-label">Coming Soon</div>
    <span class="sb-item disabled">
      <svg class="sb-icon"><use href="#ic-scale"/></svg>
      <span>Reconciliation</span>
      <span class="sb-badge">Soon</span>
    </span>
    <span class="sb-item disabled">
      <svg class="sb-icon"><use href="#ic-chart"/></svg>
      <span>Report Builder</span>
      <span class="sb-badge">Soon</span>
    </span>
    <span class="sb-item disabled">
      <svg class="sb-icon"><use href="#ic-shield"/></svg>
      <span>Data Validator</span>
      <span class="sb-badge">Soon</span>
    </span>

    <div class="sb-spacer"></div>
    <div class="sb-divider"></div>

    <a class="sb-item" href="#">
      <svg class="sb-icon"><use href="#ic-help"/></svg>
      <span>Help &amp; Support</span>
    </a>
    <a class="sb-item" href="#">
      <svg class="sb-icon"><use href="#ic-settings"/></svg>
      <span>Settings</span>
    </a>

    <div class="sb-user">
      <div class="sb-avatar">@initials</div>
      <div style="min-width:0">
        <div class="sb-user-name">@displayName</div>
        <div class="sb-user-role">@role</div>
      </div>
      <svg width="14" height="14" style="margin-left:auto;color:rgba(255,255,255,0.4);flex-shrink:0"><use href="#ic-chevron-d"/></svg>
    </div>
    <a class="sb-item" style="font-size:12px;opacity:0.75" href="@signOutUrl">
      <svg class="sb-icon"><use href="#ic-x"/></svg>
      <span>Sign out</span>
    </a>
  </aside>

  @* ── Main area ────────────────────────────────────────────── *@
  <div class="main">
    @RenderBody()
  </div>

</div><!-- /.app -->

<div class="global-loader" id="globalLoader"></div>
<script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
<script>
  function showLoader() { document.getElementById('globalLoader').classList.add('is-active'); }
  function hideLoader() { document.getElementById('globalLoader').classList.remove('is-active'); }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
