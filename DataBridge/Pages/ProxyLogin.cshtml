@page
@model DataBridge.Pages.ProxyLoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Proxy Login — DataBridge</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            background: #F4F7FB;
            color: #1A2533;
            min-height: 100vh;
            display: grid;
            place-items: center;
        }
        .login-card {
            background: #fff;
            border: 1px solid #D8E2EE;
            border-radius: 12px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            font-size: 15px;
            color: #1A2533;
            margin-bottom: 28px;
        }
        .brand-mark {
            width: 30px; height: 30px;
            background: linear-gradient(135deg, #2E75B6, #5FA8E4);
            border-radius: 7px;
            display: grid;
            place-items: center;
            color: #fff;
        }
        h1 { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
        .subtitle { font-size: 13px; color: #6B7A8D; margin-bottom: 28px; }
        .field { margin-bottom: 18px; }
        .field label {
            display: block;
            font-size: 12.5px;
            font-weight: 600;
            color: #1A2533;
            margin-bottom: 6px;
        }
        .field select, .field input[type="password"] {
            width: 100%;
            height: 38px;
            padding: 0 12px;
            border: 1px solid #D8E2EE;
            border-radius: 6px;
            font-family: inherit;
            font-size: 14px;
            color: #1A2533;
            background: #fff;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
        }
        .field select:focus, .field input[type="password"]:focus {
            border-color: #2E75B6;
            box-shadow: 0 0 0 3px rgba(46,117,182,0.15);
        }
        .error-banner {
            background: #FCE9E6;
            color: #C0392B;
            border: 1px solid #F0C4BD;
            border-radius: 6px;
            padding: 10px 14px;
            font-size: 13px;
            margin-bottom: 18px;
        }
        .btn-submit {
            width: 100%;
            height: 40px;
            background: #2E75B6;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-family: inherit;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s, box-shadow .15s;
        }
        .btn-submit:hover { background: #2666A0; box-shadow: 0 2px 8px rgba(46,117,182,0.35); }
        .btn-submit:active { transform: translateY(1px); }
        .divider {
            display: flex; align-items: center; gap: 10px;
            margin: 20px 0;
            color: #9AA8B9; font-size: 12px;
        }
        .divider::before, .divider::after {
            content: ''; flex: 1;
            border-top: 1px solid #D8E2EE;
        }
        .btn-ms {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            width: 100%; height: 40px;
            background: #fff;
            color: #1A2533;
            border: 1px solid #D8E2EE;
            border-radius: 6px;
            font-family: inherit;
            font-size: 13.5px;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: background .15s, border-color .15s;
        }
        .btn-ms:hover { background: #F4F7FB; border-color: #C2D1E3; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand">
            <div class="brand-mark">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 9h14M14 5l4 4-4 4"/><path d="M20 15H6M10 19l-4-4 4-4"/>
                </svg>
            </div>
            DataBridge
        </div>

        <h1>Proxy Login</h1>
        <p class="subtitle">Select a registered user and enter the admin OTP to sign in on their behalf.</p>

        @if (Model.ErrorMessage is not null)
        {
            <div class="error-banner">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="field">
                <label for="SelectedUserId">User</label>
                <select id="SelectedUserId" name="SelectedUserId" required>
                    <option value="" disabled selected>Select a user…</option>
                    @foreach (var u in Model.Users)
                    {
                        <option value="@u.Id">@u.DisplayName (@u.Email)</option>
                    }
                </select>
            </div>

            <div class="field">
                <label for="Otp">OTP</label>
                <input id="Otp" name="Otp" type="password" placeholder="Enter OTP" autocomplete="one-time-code" required />
            </div>

            <button type="submit" class="btn-submit">Sign In</button>
        </form>

        <div class="divider">or</div>

        <a class="btn-ms" href="/MicrosoftIdentity/Account/SignIn">
            <svg width="16" height="16" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="1" width="9" height="9" fill="#F25022"/>
                <rect x="11" y="1" width="9" height="9" fill="#7FBA00"/>
                <rect x="1" y="11" width="9" height="9" fill="#00A4EF"/>
                <rect x="11" y="11" width="9" height="9" fill="#FFB900"/>
            </svg>
            Sign in with Microsoft
        </a>
    </div>
</body>
</html>
