@page
@model DataBridge.Pages.LoginModel
@{
    Layout = null;
    var returnUrl = HttpContext.Request.Query["ReturnUrl"].FirstOrDefault() ?? "/";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — DataBridge</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            background: #F4F7FB;
            color: #1A2533;
            min-height: 100vh;
            display: grid;
            place-items: center;
        }
        .login-card {
            background: #fff;
            border: 1px solid #D8E2EE;
            border-radius: 12px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 2px 16px rgba(0,0,0,0.06);
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            font-size: 15px;
            color: #1A2533;
            margin-bottom: 28px;
        }
        .brand-mark {
            width: 30px; height: 30px;
            background: linear-gradient(135deg, #2E75B6, #5FA8E4);
            border-radius: 7px;
            display: grid;
            place-items: center;
            color: #fff;
        }
        h1 { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
        .subtitle { font-size: 13px; color: #6B7A8D; margin-bottom: 32px; }
        .option-btn {
            display: flex;
            align-items: center;
            gap: 14px;
            width: 100%;
            padding: 16px 18px;
            border: 1px solid #D8E2EE;
            border-radius: 8px;
            background: #fff;
            cursor: pointer;
            text-decoration: none;
            color: #1A2533;
            transition: border-color .15s, box-shadow .15s, background .15s;
            margin-bottom: 12px;
        }
        .option-btn:hover {
            border-color: #2E75B6;
            box-shadow: 0 0 0 3px rgba(46,117,182,0.1);
            background: #F8FBFF;
        }
        .option-icon {
            width: 38px; height: 38px;
            border-radius: 8px;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }
        .option-icon.sso   { background: #E4EEF8; color: #2E75B6; }
        .option-icon.proxy { background: #F0FDF4; color: #166534; }
        .option-text { text-align: left; }
        .option-title { font-size: 14px; font-weight: 600; }
        .option-desc  { font-size: 12px; color: #6B7A8D; margin-top: 2px; }
        .option-arrow { margin-left: auto; color: #9AA8B9; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand">
            <div class="brand-mark">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 9h14M14 5l4 4-4 4"/><path d="M20 15H6M10 19l-4-4 4-4"/>
                </svg>
            </div>
            DataBridge
        </div>

        <h1>Sign In</h1>
        <p class="subtitle">Choose how you'd like to access DataBridge.</p>

        <a class="option-btn" href="/MicrosoftIdentity/Account/SignIn">
            <div class="option-icon sso">
                <svg width="20" height="20" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="1" y="1" width="9" height="9" fill="#F25022"/>
                    <rect x="11" y="1" width="9" height="9" fill="#7FBA00"/>
                    <rect x="1" y="11" width="9" height="9" fill="#00A4EF"/>
                    <rect x="11" y="11" width="9" height="9" fill="#FFB900"/>
                </svg>
            </div>
            <div class="option-text">
                <div class="option-title">Sign in with Microsoft</div>
                <div class="option-desc">Use your Larsen &amp; Toubro account</div>
            </div>
            <svg class="option-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 6 6 6-6 6"/>
            </svg>
        </a>

        <a class="option-btn" href="/ProxyLogin?ReturnUrl=@Uri.EscapeDataString(returnUrl)">
            <div class="option-icon proxy">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <path d="M9 12l2 2 4-4"/>
                </svg>
            </div>
            <div class="option-text">
                <div class="option-title">Proxy Login</div>
                <div class="option-desc">Login access on behalf of a registered user</div>
            </div>
            <svg class="option-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 6 6 6-6 6"/>
            </svg>
        </a>
    </div>
</body>
</html>
